digraph JobPortal {
  rankdir=LR;
  node [shape=box, style=rounded, fontname="Arial"];

  // Layers
  subgraph cluster_routes {
    label="Routes";
    "auth.routes.js";
    "job.routes.js";
    "user.routes.js";
    "company.routes.js";
    "application.route.js";
    "github.routes.js";
  }

  subgraph cluster_controllers {
    label="Controllers";
    "auth.controller.js";
    "job.controller.js";
    "user.controller.js";
    "company.controller.js";
    "application.controller.js";
  }

  subgraph cluster_services {
    label="Services";
    "auth.service.js";
    "job.service.js";
    "user.service.js";
    "company.service.js";
    "application.service.js";
    "upload.service.js";
  }

  subgraph cluster_db {
    label="Database / Lib";
    "db.js";
    "supabase.js";
  }

  // Flow connections
  "auth.routes.js" -> "auth.controller.js";
  "job.routes.js" -> "job.controller.js";
  "user.routes.js" -> "user.controller.js";
  "company.routes.js" -> "company.controller.js";
  "application.route.js" -> "application.controller.js";

  "auth.controller.js" -> "auth.service.js";
  "job.controller.js" -> "job.service.js";
  "user.controller.js" -> "user.service.js";
  "company.controller.js" -> "company.service.js";
  "application.controller.js" -> "application.service.js";

  "auth.service.js" -> "db.js";
  "job.service.js" -> "db.js";
  "user.service.js" -> "db.js";
  "company.service.js" -> "db.js";
  "application.service.js" -> "db.js";

  "upload.service.js" -> "supabase.js";
}