generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int           @id @default(autoincrement())
  name         String
  email        String        @unique
  password     String
  resume       String?
  /// ///////////////////////////////////////////////////
  /// ///////////////////////////////////////////////////
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  /// ///////////////////////////////////////////////////
  /// ///////////////////////////////////////////////////
  companyId    Int?
  role         Role          @default(job_seeker)
  avatar       String?
  bio          String?
  /// ///////////////////////////////////////////////////
  /// ///////////////////////////////////////////////////
  headline     String?
  location     String?
  phone        String?
  skills       String[]
  refreshToken String?
  applications Application[]
  savedJobs    SavedJob[]
  company      Company?      @relation(fields: [companyId], references: [id])

  @@index([email])
}

model Company {
  id          Int      @id @default(autoincrement())
  companyName String
  email       String   @unique
  /// ///////////////////////////////////////////////////
  /// ///////////////////////////////////////////////////
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  description String?
  location    String?
  logo        String?
  coverImage  String?
  website     String?
  industry    String?
  size        String?
  foundedYear Int?
  officeCount Int?
  gallery     String[]
  specialties String[]
  jobs        Job[]
  users       User[]
}

model Job {
  id           Int           @id @default(autoincrement())
  title        String
  location     String
  description  String?
  /// ///////////////////////////////////////////////////
  /// ///////////////////////////////////////////////////
  companyId    Int
  /// ///////////////////////////////////////////////////
  /// ///////////////////////////////////////////////////
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  jobType      JobType
  salaryNegotiable Boolean   @default(false)
  salaryMax    Int?
  salaryMin    Int?
  status       JobStatus     @default(open)
  benefits     String?
  requirements String?
  category     String?
  applications Application[]
  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  savedBy      SavedJob[]

  @@index([companyId])
  @@index([location])
  @@index([jobType])
  @@index([status])
}

model Application {
  id          Int               @id @default(autoincrement())
  appliedDate DateTime          @default(now())
  /// ///////////////////////////////////////////////////
  /// ///////////////////////////////////////////////////
  userId      Int
  jobId       Int
  status      ApplicationStatus @default(pending)
  coverLetter String?
  job         Job               @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
  @@index([userId])
  @@index([jobId])
}

model Session {
  sid    String   @id @map("sid")
  sess   Json     @map("sess")
  expire DateTime @map("expire")

  @@index([expire], map: "IDX_session_expire")
  @@map("session")
}

model DeletedAsset {
  id        String   @id @default(uuid())
  filePath  String   @map("file_path")
  deletedAt DateTime @default(now()) @map("deleted_at")

  @@map("deleted_assets")
}

model SavedJob {
  id        Int      @id @default(autoincrement())
  userId    Int
  jobId     Int
  createdAt DateTime @default(now())
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
  @@index([userId])
  @@index([jobId])
}

enum Role {
  job_seeker
  company_admin
  super_admin
}

enum JobType {
  full_time
  part_time
  contract
  internship
  remote
}

enum JobStatus {
  open
  closed
}

enum ApplicationStatus {
  pending
  reviewed
  accepted
  rejected
}
