generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearchPostgres"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int           @id @default(autoincrement())
  name         String
  email        String        @unique
  password     String
  resume       String?
  /// ///////////////////////////////////////////////////
  /// ///////////////////////////////////////////////////
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  /// ///////////////////////////////////////////////////
  /// ///////////////////////////////////////////////////
  companyId    Int?
  role         Role          @default(job_seeker)
  avatar       String?
  bio          String?
  /// ///////////////////////////////////////////////////
  /// ///////////////////////////////////////////////////
  headline     String?
  location     String?
  phone        String?
  skills       String[]
  refreshToken String?
  resetPasswordToken String?
  resetPasswordExpires DateTime?
  isVerified   Boolean       @default(false)
  isSuspended  Boolean       @default(false)
  warningCount Int           @default(0)
  verificationToken String?   @unique
  verificationExpires DateTime?
  applications Application[]
  savedJobs    SavedJob[]
  company      Company?      @relation(fields: [companyId], references: [id])
  warningsIssued   WarningLog[] @relation("IssuedWarnings")
  warningsReceived WarningLog[] @relation("UserWarnings")

  @@index([email])
  @@index([resetPasswordToken])
  @@index([verificationToken])
}

model Company {
  id          Int      @id @default(autoincrement())
  companyName String
  email       String   @unique
  /// ///////////////////////////////////////////////////
  /// ///////////////////////////////////////////////////
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  description String?
  location    String?
  logo        String?
  coverImage  String?
  website     String?
  industry    String?
  size        String?
  foundedYear Int?
  officeCount Int?
  gallery     String[]
  specialties String[]
  mapUrl      String?
  latitude    Float?
  longitude   Float?
  isVerified  Boolean  @default(false)
  isSuspended Boolean  @default(false)
  warningCount Int     @default(0)
  jobs        Job[]
  users       User[]
  warnings    WarningLog[]
}

model Job {
  id           Int           @id @default(autoincrement())
  title        String
  location     String
  description  String?
  /// ///////////////////////////////////////////////////
  /// ///////////////////////////////////////////////////
  companyId    Int
  /// ///////////////////////////////////////////////////
  /// ///////////////////////////////////////////////////
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  jobType      JobType
  salaryNegotiable Boolean   @default(false)
  salaryMax    Int?
  salaryMin    Int?
  status       JobStatus     @default(open)
  benefits     String?
  requirements String?
  category     String?
  skills       String[]
  tags         String[]
  applications Application[]
  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  savedBy      SavedJob[]

  @@index([companyId])
  @@index([location])
  @@index([jobType])
  @@index([status])
}

model Application {
  id          Int               @id @default(autoincrement())
  appliedDate DateTime          @default(now())
  /// ///////////////////////////////////////////////////
  /// ///////////////////////////////////////////////////
  userId      Int
  jobId       Int
  status      ApplicationStatus @default(pending)
  coverLetter String?
  applyCount  Int               @default(1)
  job         Job               @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
  @@index([userId])
  @@index([jobId])
}

model Session {
  sid    String   @id @map("sid")
  sess   Json     @map("sess")
  expire DateTime @map("expire")

  @@index([expire], map: "IDX_session_expire")
  @@map("session")
}

model DeletedAsset {
  id        String   @id @default(uuid())
  filePath  String   @map("file_path")
  bucket    String   @default("logos")
  deletedAt DateTime @default(now()) @map("deleted_at")

  @@map("deleted_assets")
}

model SavedJob {
  id        Int      @id @default(autoincrement())
  userId    Int
  jobId     Int
  createdAt DateTime @default(now())
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
  @@index([userId])
  @@index([jobId])
}

enum Role {
  job_seeker
  company_admin
  super_admin
}

enum JobType {
  full_time
  part_time
  contract
  internship
  remote
}

enum JobStatus {
  open
  closed
}

enum ApplicationStatus {
  pending
  reviewed
  accepted
  rejected
  spam
}

model WarningLog {
  id              Int      @id @default(autoincrement())
  reason          String[]
  createdAt       DateTime @default(now())
  issuedById      Int
  issuedBy        User     @relation("IssuedWarnings", fields: [issuedById], references: [id])
  
  targetUserId    Int?
  targetUser      User?    @relation("UserWarnings", fields: [targetUserId], references: [id], onDelete: Cascade)
  
  targetCompanyId Int?
  targetCompany   Company? @relation(fields: [targetCompanyId], references: [id], onDelete: Cascade)

  @@index([targetUserId])
  @@index([targetCompanyId])
  @@index([issuedById])
}
