# Example environment variables for local development (do NOT commit real secrets)

# Primary database connection used by Prisma
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE

# Neon MCP / Neon API (used only for MCP server or remote agents)
# Add your Neon API key to local .env or CI secrets when needed.
NEON_API_KEY=your_neon_api_key_here
NEON_PROJECT_ID=your_neon_project_id_here
NEON_DEFAULT_BRANCH=main

# Application settings
PORT=5000
JWT_SECRET=supersecretkey
